# DeepResearch Agent - Environment Variables Example
# Copy this file to .env and fill in your actual values

# ============================================================
# APP
# ============================================================
APP_NAME=DeepResearch Agent
DEBUG=true

# ============================================================
# DATABASE (PostgreSQL)
# ============================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/deepresearch

# ============================================================
# CHROMA Vector DB
# ============================================================
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ============================================================
# SECURITY (Encryption key for API Keys - CHANGE THIS!)
# Must be at least 32 characters
# ============================================================
ENCRYPTION_KEY=CHANGE_ME_32BYTE_ENCRYPTION_KEY!!

# ============================================================
# SEARCH API (Tavily - https://tavily.com)
# ============================================================
TAVILY_API_KEY=your_tavily_api_key_here

# ============================================================
# LLM PROVIDERS (Users configure their own via the UI)
# Supported: openai, anthropic, deepseek
# ============================================================
# OPENAI_API_KEY=sk-your-openai-key-here
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
# DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# ============================================================
# CORS (Frontend URL)
# ============================================================
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
