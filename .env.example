# DeepResearch Agent - Environment Variables Example
# Copy this file to .env and fill in your actual values

# ============================================================
# APP
# ============================================================
APP_NAME=DeepResearch Agent
DEBUG=true

# ============================================================
# DATABASE (PostgreSQL)
# ============================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/deepresearch

# ============================================================
# CHROMA Vector DB
# ============================================================
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ============================================================
# SECURITY (Encryption key for API Keys - CHANGE THIS!)
# Must be at least 32 characters
# ============================================================
ENCRYPTION_KEY=CHANGE_ME_32BYTE_ENCRYPTION_KEY!!

# ============================================================
# SEARCH API (Tavily - https://tavily.com)
# ============================================================
TAVILY_API_KEY=your_tavily_api_key_here

# ============================================================
# LLM PROVIDERS (Users configure their own via the UI)
# Supported: openai, anthropic, deepseek
# ============================================================
# OPENAI_API_KEY=sk-your-openai-key-here
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
# DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# ============================================================
# MCP_Visual (image/audio analysis for uploaded media)
# OPENAI_API_KEY is required for image and audio understanding.
# If users select OpenAI in the UI, DeepResearch can reuse that key
# when OPENAI_API_KEY is not set here.
# ============================================================
MCP_VISUAL_ALLOWED_DIRS=
MCP_VISUAL_MAX_FILE_MB=25
MCP_VISUAL_MAX_DOWNLOAD_MB=25
MCP_VISUAL_REQUEST_TIMEOUT_SECONDS=60
OPENAI_VISION_MODEL=gpt-5.4-mini
OPENAI_SUMMARY_MODEL=gpt-5.4-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_DIARIZE_MODEL=gpt-4o-transcribe-diarize

# ============================================================
# CORS (Frontend URL)
# ============================================================
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
